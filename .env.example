# Environment variables for Agento

# ============================================
# LLM API KEYS (at least one required)
# ============================================

# OpenRouter (recommended - 100+ models)
# Get key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Alternative LLM providers (optional)
# DEEPSEEK_API_KEY=your-deepseek-key
# GOOGLE_API_KEY=your-google-key

# ============================================
# MODEL CONFIGURATION
# ============================================

# Default model for all tasks
DEFAULT_MODEL=openrouter/free

# Task-specific models (optional overrides)
# CODE_MODEL=qwen/qwen3-coder-480b-a35b:free
# DEVOPS_MODEL=openrouter/free
# PLANNING_MODEL=deepseek/deepseek-r1-0528:free

# ============================================
# MEMORY CONFIGURATION
# ============================================

# Directory for memory persistence
MEMORY_DIR=./memory_data

# Embedding model (sentence-transformers)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ============================================
# DOCKER CONFIGURATION
# ============================================

# Enable Docker for command isolation
DOCKER_ENABLED=true

# Docker socket path (default for Linux/macOS)
DOCKER_SOCKET=/var/run/docker.sock

# ============================================
# MCP CONFIGURATION
# ============================================

# Enable MCP support
MCP_ENABLED=true

# MCP servers (add as needed)
# MCP_GITHUB_TOKEN=ghp_your-token
# MCP_SLACK_TOKEN=xoxb-your-token

# ============================================
# LOGGING
# ============================================

LOG_LEVEL=INFO
LOG_FILE=./logs/agento.log

# ============================================
# SAFETY
# ============================================

# Autonomy level (0=confirm all, 1=safe auto, 2=full auto)
AUTONOMY_LEVEL=1

# Allow dangerous commands (rm -rf, etc.)
ALLOW_DANGEROUS_COMMANDS=false

# Maximum command timeout in seconds
MAX_COMMAND_TIMEOUT=300

# ============================================
# COLAB (for Google Colab deployment)
# ============================================

# Set via Colab secrets, not here
# COLAB_API_KEY=your-colab-secret
